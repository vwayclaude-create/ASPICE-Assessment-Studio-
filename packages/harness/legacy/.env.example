# Pick ONE provider. If both keys are set, explicit
# ASPICE_LLM_PROVIDER (or `llm.provider` option) wins;
# otherwise Anthropic is preferred.

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Force a specific provider ('anthropic' | 'openai')
# ASPICE_LLM_PROVIDER=openai

# Override the default model (per-provider default: claude-opus-4-7 / gpt-4o)
# ASPICE_LLM_MODEL=gpt-4o
